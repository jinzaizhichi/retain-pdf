#!/usr/bin/env sh
set -eu

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

if ! printf '%s\n' "$STAGED_FILES" | grep -Eq '^(frontend/|desktop/scripts/prepare-app\.mjs|desktop/scripts/check-frontend-bundle\.mjs|desktop/package\.json)'; then
  exit 0
fi

printf '%s\n' "[pre-commit] frontend/desktop sync-sensitive files changed."
printf '%s\n' "[pre-commit] Run before pushing: npm --prefix desktop run verify-frontend-sync"
printf '%s\n' "[pre-commit] This hook no longer rewrites generated desktop frontend files."
